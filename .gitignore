# ==========================================
# Environment & Secrets
# ==========================================
.env
.env.local
.env.*.local
!.env.example
!.env.example.php

# ==========================================
# Docker & Database Host Directories
# ==========================================
logs/apache/*
!logs/apache/.gitkeep
logs/php/*
!logs/php/.gitkeep
/dbdata/
/data/
/mysql_data/

# ==========================================
# Grav CMS Cache & Runtime Directories
# ==========================================
src/assets/*
!src/assets/.gitkeep
src/backup/*
!src/backup/.gitkeep
src/cache/*
!src/cache/.gitkeep
src/images/*
!src/images/.gitkeep
src/logs/*
!src/logs/.gitkeep
src/tmp/*
!src/tmp/.gitkeep

# Grav Vendor Dependencies
src/vendor/

# Temporary / Testing Scripts
src/diagnostics.php

# ==========================================
# Grav Sensitive User Data & Runtime Cache
# ==========================================
# Exclude admin account YAML files containing password hashes
src/user/accounts/*
!src/user/accounts/.gitkeep

# Exclude user session & plugin runtime data
src/user/data/*
!src/user/data/.gitkeep
src/user/data/cache/*
src/user/data/tmp/*

# Exclude Package Manager & local config state
src/user/config/gpm.yaml
src/user/env.php

# ==========================================
# General Logs & Dumps
# ==========================================
*.log
*.sql
*.sql.gz

# ==========================================
# Node.js & Frontend Build Tools (Themes/Plugins)
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ==========================================
# Operating System, IDEs & AI Tools
# ==========================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# IDEs, Editors & Assistants
.vscode/
.idea/
.vs/
.zed/
.gemini/
.claude/
.cursor/
*.swp
*.swo
*~
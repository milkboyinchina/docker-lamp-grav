# ==========================================
# Network Configuration
# ==========================================
DOCKER_NETWORK_NAME=grav-network

# ==========================================
# Stack Component Versions
# ==========================================
PHP_VERSION=8.3-apache
MARIADB_VERSION=latest

# ==========================================
# Server & Domain Configuration
# ==========================================
SERVER_NAME=localhost
SERVER_ADMIN=webmaster@localhost

# ==========================================
# Port Mappings
# ==========================================
HTTP_PORT=80
ADMINER_PORT=8080

# ==========================================
# MariaDB Database Credentials
# ==========================================
MARIADB_DATABASE=grav_db
MARIADB_ROOT_PASSWORD=change_this_root_password
MARIADB_USER=grav_user
MARIADB_PASSWORD=change_this_user_password
# ==========================================
# Webserver Base Image Selection
# ==========================================
# Debian Apache options: php:8.3-apache, php:8.2-apache, php:8.3-apache-bookworm
PHP_IMAGE=php:8.3-apache

# ==========================================
# Compose Profiles Configuration
# ==========================================
# Enable optional services by profile name (comma-separated).
# Examples:
#   COMPOSE_PROFILES=db,adminer   (Enable both MariaDB and Adminer)
#   COMPOSE_PROFILES=db           (Enable MariaDB only)
#   COMPOSE_PROFILES=             (Lightweight mode: Apache webserver only)
COMPOSE_PROFILES=db,adminer

# ==========================================
# Restart Policy Configuration
# ==========================================
# Container restart policy for all stack services.
# Options: unless-stopped, always, on-failure, no
RESTART_POLICY=unless-stopped

# ==========================================
# Database Image Version
# ==========================================
MARIADB_VERSION=latest

# ==========================================
# Server & Domain Configuration
# ==========================================
SERVER_NAME=www.example.com
SERVER_ADMIN=webmaster@example.com

# ==========================================
# Port Mappings
# ==========================================
HTTP_PORT=80
ADMINER_PORT=8080

# ==========================================
# Host Volume Paths
# ==========================================
# Application web root directory mounted to container /var/www/html
SRC_PATH=./src

# Apache webserver access and error logs folder mounted to container /var/log/apache2
LOGS_APACHE_PATH=./logs/apache

# PHP runtime error logs folder mounted to container /var/log/php
LOGS_PHP_PATH=./logs/php

# Apache VirtualHost configuration file mounted to container /etc/apache2/sites-available/000-default.conf
CONFIG_APACHE_PATH=./config/apache/000-default.conf

# Custom php.ini configuration overrides file mounted to container /usr/local/etc/php/conf.d/custom.ini
CONFIG_PHP_PATH=./config/php/custom.ini

# Custom MariaDB server configuration file mounted to container /etc/mysql/conf.d/custom.cnf
CONFIG_MYSQL_PATH=./config/mysql/custom.cnf

# MariaDB persistent database volume name or host directory path mounted to container /var/lib/mysql
DB_VOLUME_NAME=dbdata

# ==========================================
# MariaDB Database Credentials
# ==========================================
MARIADB_DATABASE=grav_db
MARIADB_ROOT_PASSWORD=change_this_root_password
MARIADB_USER=grav_user
MARIADB_PASSWORD=change_this_user_password

# ==========================================
# Backup Configuration
# ==========================================
# Host directory output path for generated backup archives
BACKUP_DIR=./backups

# Custom filename prefix for backup files (e.g. grav_lamp_www_20260722_120000.tar.gz)
BACKUP_PREFIX=grav_lamp

# Path to append backup operation execution logs and warnings
LOGS_BACKUP_PATH=./logs/backup.log
<article class="content-item h-entry">

{% if not hero_image_name %}
    <header class="content-title text-center">
        {% include 'partials/blog/title.html.twig' with {title_level: 'h1'} %}
        {% if page.header.subtitle %}
            <p class="lead">{{ page.header.subtitle }}</p>
        {% endif %}
        {% include 'partials/blog/date.html.twig' %}
        {% include 'partials/blog/taxonomy.html.twig' %}
    </header>
{% endif %}

    <div class="e-content">
        {{ page.content|raw }}
    </div>

    {% if page.header.continue_link is same as(true) and config.plugins.comments.enabled %}
        {% include 'partials/comments.html.twig' ignore missing %}
    {% endif %}
</article>

<nav class="prev-next" aria-label="Post navigation">
    {% if not page.isLast %}
        <a class="btn btn-ghost" href="{{ page.prevSibling.url }}"><i class="fa-solid fa-angle-left" aria-hidden="true"></i> {{ 'THEME_QUARK2.BLOG.ITEM.PREV_POST'|t }}</a>
    {% else %}<span></span>{% endif %}

    {% if not page.isFirst %}
        <a class="btn btn-ghost" href="{{ page.nextSibling.url }}">{{ 'THEME_QUARK2.BLOG.ITEM.NEXT_POST'|t }} <i class="fa-solid fa-angle-right" aria-hidden="true"></i></a>
    {% else %}<span></span>{% endif %}
</nav>

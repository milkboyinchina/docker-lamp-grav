<section class="section modular-features {{ page.header.class }}">
    <div class="container">
        <div class="frame-box">
            {{ content|raw }}

            <div class="columns">
            {% for feature in page.header.features %}
                <div class="column">
                    {% if feature.url %}<a href="{{ feature.url }}" style="text-decoration:none;color:inherit;display:block;">{% endif %}
                    <div class="feature-icon">
                        {% if feature.icon %}<i class="fa-solid fa-{{ feature.icon }}" aria-hidden="true"></i>{% endif %}
                        {% if feature.header %}<h6>{{ feature.header }}</h6>{% endif %}
                    </div>
                    <div class="feature-content">
                        {% if feature.text %}<p>{{ feature.text }}</p>{% endif %}
                    </div>
                    {% if feature.url %}</a>{% endif %}
                </div>
            {% endfor %}
            </div>
        </div>
    </div>
</section>
